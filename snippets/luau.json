  "-- game.Players.PlayerAdded": {
    "prefix": "PlayerAdded",
    "body": "game.Players.PlayerAdded:Connect(function(${1:player})\n\t${0}\nend)",
    "description": "PlayerAdded event"
  },
  "-- game.Players.PlayerRemoving": {
    "prefix": "PlayerRemoving",
    "body": "game.Players.PlayerRemoving:Connect(function(${1:player})\n\t${0}\nend)",
    "description": "PlayerRemoving event"
  },
  "-- player.CharacterAdded": {
    "prefix": "CharacterAdded",
    "body": "${1:player}.CharacterAdded:Connect(function(${2:character})\n\t${0}\nend)",
    "description": "CharacterAdded event"
  },
  "-- WaitForChild": {
    "prefix": "wfc",
    "body": "${1:parent}:WaitForChild(\"${2:childName}\")",
    "description": "WaitForChild()"
  },
  "-- FindFirstChild": {
    "prefix": "ffc",
    "body": "${1:parent}:FindFirstChild(\"${2:childName}\")",
    "description": "FindFirstChild()"
  },
  "-- FindFirstChildOfClass": {
    "prefix": "ffcoc",
    "body": "${1:parent}:FindFirstChildOfClass(\"${2:className}\")",
    "description": "FindFirstChildOfClass()"
  },
  "-- FindFirstChildWhichIsA": {
    "prefix": "ffcwia",
    "body": "${1:parent}:FindFirstChildWhichIsA(\"${2:className}\")",
    "description": "FindFirstChildWhichIsA()"
  },
  "-- FindFirstAncestorOfClass": {
    "prefix": "ffaoc",
    "body": "${1:instance}:FindFirstAncestorOfClass(\"${2:className}\")",
    "description": "FindFirstAncestorOfClass()"
  },
  "-- GetChildren": {
    "prefix": "gc",
    "body": "${1:parent}:GetChildren()",
