  },
  "-- math.abs": {
    "prefix": "mabs",
    "body": "math.abs(${1:value})",
    "description": "math.abs()"
  },
  "-- math.lerp (manual)": {
    "prefix": "lerp",
    "body": "${1:a} + (${2:b} - ${1:a}) * ${3:t}",
    "description": "Linear interpolation"
  },

  "-- OOP Class": {
    "prefix": "class",
    "body": "local ${1:ClassName} = {}\n${1}.__index = ${1}\n\nfunction ${1}.new(${2})\n\tlocal self = setmetatable({}, ${1})\n\t${0}\n\treturn self\nend\n\nfunction ${1}:${3:Method}(${4})\n\t\nend\n\nreturn ${1}",
    "description": "OOP class template"
  },

  "-- Module script template": {
    "prefix": "module",
    "body": "local ${1:Module} = {}\n\n${0}\n\nreturn ${1}",
    "description": "ModuleScript template"
  },
  "-- Script header comment": {
    "prefix": "header",
    "body": "-- ${1:Script Name}\n-- Author: ${2:Author}\n-- Date: ${3:2026}\n-- Description: ${4}\n\n${0}",
    "description": "Script header comment"
  },

  "-- Humanoid from character": {
    "prefix": "humanoid",
    "body": "local ${1:humanoid} = ${2:character}:FindFirstChildOfClass(\"Humanoid\")",
    "description": "Get Humanoid from character"
  },
  "-- HumanoidRootPart": {
    "prefix": "hrp",
    "body": "local ${1:hrp} = ${2:character}:FindFirstChild(\"HumanoidRootPart\")",
    "description": "Get HumanoidRootPart"
  },
  "-- GetPlayers loop": {
    "prefix": "forplayers",
    "body": "for _, ${1:player} in ipairs(game.Players:GetPlayers()) do\n\t${0}\nend",
    "description": "Loop over all players"
  },
  "-- LocalPlayer": {
    "prefix": "lp",
    "body": "local LocalPlayer = game.Players.LocalPlayer",
    "description": "LocalPlayer"
  },
  "-- LocalPlayer Character": {
    "prefix": "lpchar",
    "body": "local LocalPlayer = game.Players.LocalPlayer\nlocal character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()",
    "description": "LocalPlayer + Character"
  },

  "-- BindToClose": {
    "prefix": "bindclose",
    "body": "game:BindToClose(function()\n\t${0}\nend)",
    "description": "game:BindToClose()"
  },
  "-- game.Loaded": {
    "prefix": "loaded",
    "body": "if not game:IsLoaded() then\n\tgame.Loaded:Wait()\nend\n${0}",
    "description": "Wait for game to load"
  }
}
