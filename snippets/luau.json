  },
  "-- RaycastParams": {
    "prefix": "rayparams",
    "body": "local ${1:params} = RaycastParams.new()\n${1}.FilterDescendantsInstances = { ${2:workspace} }\n${1}.FilterType = Enum.RaycastFilterType.${3:Exclude}",
    "description": "RaycastParams setup"
  },
  "-- workspace:Raycast": {
    "prefix": "raycast",
    "body": "local ${1:result} = workspace:Raycast(${2:origin}, ${3:direction}, ${4:params})\nif ${1} then\n\tlocal ${5:hit} = ${1}.Instance\n\t${0}\nend",
    "description": "workspace:Raycast()"
  },

  "-- RunService.Heartbeat": {
