{
  "-- if statement": {
    "prefix": "if",
    "body": "if ${1:condition} then\n\t${0}\nend",
    "description": "If statement"
  },
  "-- if-else statement": {
    "prefix": "ife",
    "body": "if ${1:condition} then\n\t${2}\nelse\n\t${0}\nend",
    "description": "If-else statement"
  },
  "-- elseif": {
    "prefix": "elseif",
    "body": "elseif ${1:condition} then\n\t${0}",
    "description": "Elseif branch"
  },
  "-- while loop": {
    "prefix": "while",
    "body": "while ${1:condition} do\n\t${0}\nend",
    "description": "While loop"
  },
  "-- repeat loop": {
    "prefix": "repeat",
    "body": "repeat\n\t${0}\nuntil ${1:condition}",
    "description": "Repeat-until loop"
  },
  "-- for numeric loop": {
    "prefix": "for",
    "body": "for ${1:i} = ${2:1}, ${3:10} do\n\t${0}\nend",
    "description": "Numerical for loop"
  },
  "-- for in pairs": {
    "prefix": "forp",
    "body": "for ${1:k}, ${2:v} in pairs(${3:t}) do\n\t${0}\nend",
    "description": "For-in pairs loop"
  },
  "-- for in ipairs": {
    "prefix": "fori",
    "body": "for ${1:i}, ${2:v} in ipairs(${3:t}) do\n\t${0}\nend",
    "description": "For-in ipairs loop"
  },
  "-- do block": {
    "prefix": "do",
    "body": "do\n\t${0}\nend",
    "description": "Do block"
  },
  "-- function": {
    "prefix": "fn",
    "body": "function ${1:name}(${2})\n\t${0}\nend",
    "description": "Function definition"
  },
  "-- local function": {
    "prefix": "lfn",
    "body": "local function ${1:name}(${2})\n\t${0}\nend",
    "description": "Local function definition"
  },
  "-- anonymous function": {
    "prefix": "afn",
    "body": "function(${1})\n\t${0}\nend",
    "description": "Anonymous function"
  },
  "-- local variable": {
    "prefix": "loc",
    "body": "local ${1:name} = ${0}",
    "description": "Local variable"
  },

  "-- pcall": {
    "prefix": "pcall",
    "body": "local ${1:ok}, ${2:err} = pcall(function()\n\t${0}\nend)",
    "description": "Protected call"
  },
  "-- xpcall": {
    "prefix": "xpcall",
    "body": "local ${1:ok}, ${2:err} = xpcall(function()\n\t${0}\nend, function(err)\n\twarn(err)\nend)",
    "description": "Extended protected call"
  },

