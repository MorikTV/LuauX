  "-- math.clamp": {
    "prefix": "mclamp",
    "body": "math.clamp(${1:value}, ${2:min}, ${3:max})",
    "description": "math.clamp()"
  },
  "-- math.floor": {
    "prefix": "mfloor",
    "body": "math.floor(${1:value})",
    "description": "math.floor()"
  },
  "-- math.ceil": {
    "prefix": "mceil",
    "body": "math.ceil(${1:value})",
