    "description": "GetDescendants()"
  },
  "-- Instance.new": {
    "prefix": "new",
    "body": "local ${1:instance} = Instance.new(\"${2:ClassName}\")\n${1}.Parent = ${3:parent}\n${0}",
    "description": "Instance.new()"
  },
  "-- Instance.new Part": {
    "prefix": "newpart",
    "body": "local ${1:part} = Instance.new(\"Part\")\n${1}.Name = \"${2:Part}\"\n${1}.Size = Vector3.new(${3:4}, ${4:1}, ${5:4})\n${1}.Position = Vector3.new(${6:0}, ${7:0}, ${8:0})\n${1}.Anchored = ${9:true}\n${1}.Parent = workspace\n${0}",
    "description": "Create a new Part"
  },
  "-- Clone": {
    "prefix": "clone",
    "body": "local ${1:copy} = ${2:instance}:Clone()\n${1}.Parent = ${3:parent}",
    "description": "Clone an instance"
  },
  "-- Destroy": {
    "prefix": "dest",
    "body": "${1:instance}:Destroy()",
    "description": "Destroy()"
  },
  "-- GetAttribute": {
    "prefix": "gattr",
    "body": "${1:instance}:GetAttribute(\"${2:attribute}\")",
    "description": "GetAttribute()"
  },
  "-- SetAttribute": {
    "prefix": "sattr",
    "body": "${1:instance}:SetAttribute(\"${2:attribute}\", ${3:value})",
    "description": "SetAttribute()"
  },
  "-- GetPropertyChangedSignal": {
    "prefix": "gpcs",
    "body": "${1:instance}:GetPropertyChangedSignal(\"${2:Property}\"):Connect(function()\n\t${0}\nend)",
    "description": "GetPropertyChangedSignal():Connect()"
  },
  "-- IsA": {
    "prefix": "isa",
    "body": "${1:instance}:IsA(\"${2:ClassName}\")",
    "description": "IsA()"
  },

  "-- Connect event": {
    "prefix": "conn",
    "body": "${1:event}:Connect(function(${2})\n\t${0}\nend)",
    "description": "Event:Connect()"
  },
  "-- Disconnect": {
    "prefix": "disconn",
    "body": "local ${1:connection}\n${1} = ${2:event}:Connect(function(${3})\n\t${0}\n\t${1}:Disconnect()\nend)",
    "description": "Connect and auto-disconnect"
  },
  "-- Once": {
    "prefix": "once",
    "body": "${1:event}:Once(function(${2})\n\t${0}\nend)",
    "description": "Event:Once()"
  },

  "-- task.spawn": {
    "prefix": "tspawn",
    "body": "task.spawn(function()\n\t${0}\nend)",
    "description": "task.spawn()"
  },
  "-- task.defer": {
    "prefix": "tdefer",
    "body": "task.defer(function()\n\t${0}\nend)",
    "description": "task.defer()"
  },
  "-- task.delay": {
    "prefix": "tdelay",
    "body": "task.delay(${1:seconds}, function()\n\t${0}\nend)",
    "description": "task.delay()"
  },
  "-- task.wait": {
    "prefix": "twait",
    "body": "task.wait(${1:seconds})",
    "description": "task.wait()"
  },

  "-- RemoteEvent": {
    "prefix": "re",
    "body": "local ${1:RemoteEvent} = ReplicatedStorage:WaitForChild(\"${2:RemoteEvent}\")",
    "description": "Get RemoteEvent"
  },
  "-- RemoteFunction": {
    "prefix": "rf",
    "body": "local ${1:RemoteFunction} = ReplicatedStorage:WaitForChild(\"${2:RemoteFunction}\")",
    "description": "Get RemoteFunction"
  },
  "-- FireServer": {
    "prefix": "fs",
    "body": "${1:RemoteEvent}:FireServer(${2})",
    "description": "RemoteEvent:FireServer()"
  },
  "-- FireClient": {
    "prefix": "fc",
    "body": "${1:RemoteEvent}:FireClient(${2:player}, ${3})",
    "description": "RemoteEvent:FireClient()"
  },
  "-- FireAllClients": {
    "prefix": "fac",
    "body": "${1:RemoteEvent}:FireAllClients(${2})",
    "description": "RemoteEvent:FireAllClients()"
  },
  "-- OnServerEvent": {
    "prefix": "ose",
    "body": "${1:RemoteEvent}.OnServerEvent:Connect(function(${2:player}, ${3})\n\t${0}\nend)",
    "description": "OnServerEvent:Connect()"
  },
  "-- OnClientEvent": {
    "prefix": "oce",
    "body": "${1:RemoteEvent}.OnClientEvent:Connect(function(${2})\n\t${0}\nend)",
    "description": "OnClientEvent:Connect()"
  },
  "-- InvokeServer": {
    "prefix": "is",
    "body": "${1:RemoteFunction}:InvokeServer(${2})",
    "description": "RemoteFunction:InvokeServer()"
  },
  "-- OnServerInvoke": {
    "prefix": "osi",
    "body": "${1:RemoteFunction}.OnServerInvoke = function(${2:player}, ${3})\n\t${0}\nend",
    "description": "OnServerInvoke"
  },

  "-- TweenService:Create": {
    "prefix": "tween",
    "body": "local ${1:tween} = TweenService:Create(\n\t${2:instance},\n\tTweenInfo.new(${3:1}, Enum.EasingStyle.${4:Quad}, Enum.EasingDirection.${5:Out}),\n\t{ ${6:Property} = ${7:value} }\n)\n${1}:Play()",
    "description": "TweenService:Create() and play"
  },
  "-- TweenInfo.new": {
    "prefix": "tweeninfo",
    "body": "TweenInfo.new(${1:1}, Enum.EasingStyle.${2:Quad}, Enum.EasingDirection.${3:Out}, ${4:0}, ${5:false}, ${6:0})",
    "description": "TweenInfo.new()"
  },

  "-- DataStore get": {
    "prefix": "dsget",
    "body": "local ${1:DataStore} = DataStoreService:GetDataStore(\"${2:StoreName}\")\nlocal ${3:data}\nlocal ${4:ok}, ${5:err} = pcall(function()\n\t${3} = ${1}:GetAsync(${6:key})\nend)\nif not ${4} then\n\twarn(${5})\nend",
    "description": "DataStore GetAsync with pcall"
  },
  "-- DataStore set": {
    "prefix": "dsset",
    "body": "local ${1:ok}, ${2:err} = pcall(function()\n\t${3:DataStore}:SetAsync(${4:key}, ${5:value})\nend)\nif not ${1} then\n\twarn(${2})\nend",
    "description": "DataStore SetAsync with pcall"
  },

